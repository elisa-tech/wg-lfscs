diff --git a/drivers/mem_frag_ent/mem_frag_ent.c b/drivers/mem_frag_ent/mem_frag_ent.c
new file mode 100644
index 000000000..d807ed8bf
--- /dev/null
+++ b/drivers/mem_frag_ent/mem_frag_ent.c
@@ -0,0 +1,107 @@
+#include <linux/module.h>
+#include <linux/kernel.h>
+#include <linux/slab.h>
+#include <linux/list.h>
+#include <linux/random.h>
+#include <linux/mm.h>
+
+MODULE_LICENSE("GPL");
+MODULE_AUTHOR("blabla");
+MODULE_DESCRIPTION("A module to induce SLUB fragmentation and memory entropy");
+
+#define PHASE1_INITIAL 10
+#define PHASE1_OPS 200
+#define STACK_MAX (PHASE1_INITIAL + PHASE1_OPS)
+
+struct list_head noise_list;
+struct list_head *global_noise_head = &noise_list;
+
+struct noise_item {
+	struct list_head list;
+	void *data;
+	size_t size;
+};
+
+static size_t get_rand_size(void) {
+	unsigned int r;
+	get_random_bytes(&r, sizeof(r));
+	return (r % 4064) + 32;
+}
+
+static int __init frag_entropy_init(void) {
+	void *stack[STACK_MAX];
+	int top = -1;
+	int i;
+	unsigned int rand_val;
+	size_t target_mem, current_mem = 0;
+
+	INIT_LIST_HEAD(&noise_list);
+
+	pr_info("FragEntropy: Starting Phase 1 (Fragmentation Noise)\n");
+
+	for (i = 0; i < PHASE1_INITIAL; i++) {
+		size_t sz = get_rand_size();
+		stack[++top] = kmalloc(sz, GFP_KERNEL);
+	}
+
+	for (i = 0; i < PHASE1_OPS; i++) {
+		get_random_bytes(&rand_val, sizeof(rand_val));
+
+		if ((rand_val % 2 == 0) && (top < STACK_MAX - 1)) {
+			stack[++top] = kmalloc(get_rand_size(), GFP_KERNEL);
+		} else if (top >= 0) {
+			kfree(stack[top--]);
+		}
+	}
+
+	while (top >= 0) {
+		kfree(stack[top--]);
+	}
+
+	pr_info("FragEntropy: Starting Phase 2 (Persistent Bloat)\n");
+
+	target_mem = (totalram_pages() << PAGE_SHIFT) / 10;
+	pr_info("FragEntropy: Target memory bloat: %zu bytes\n", target_mem);
+
+	while (current_mem < target_mem) {
+		struct noise_item *item;
+		size_t sz = get_rand_size();
+
+		item = kmalloc(sizeof(struct noise_item), GFP_KERNEL);
+		if (!item) break;
+
+		item->data = kmalloc(sz, GFP_KERNEL);
+		if (!item->data) {
+			kfree(item);
+			break;
+		}
+
+		item->size = sz;
+		list_add(&item->list, global_noise_head);
+		current_mem += (sz + sizeof(struct noise_item));
+
+		if ((current_mem % (100 * 1024 * 1024)) < sz) {
+			pr_info("FragEntropy: Allocated %zu MB...\n", current_mem / 1024 / 1024);
+		}
+	}
+
+	pr_info("FragEntropy: Init complete. Memory consumed.\n");
+	return 0;
+}
+
+static void __exit frag_entropy_exit(void) {
+	struct noise_item *item, *tmp;
+
+	pr_info("FragEntropy: Cleaning up and deallocating memory...\n");
+
+	list_for_each_entry_safe(item, tmp, global_noise_head, list) {
+		kfree(item->data);
+		list_del(&item->list);
+		kfree(item);
+	}
+
+	pr_info("FragEntropy: Module unloaded.\n");
+}
+
+module_init(frag_entropy_init);
+module_exit(frag_entropy_exit);
